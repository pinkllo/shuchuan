APP_NAME=data-platform-api
API_PREFIX=/api

# Database connection used by the API container.
DATABASE_URL=postgresql+psycopg://data_platform:replace-with-strong-postgres-password@postgres:5432/data_platform
POSTGRES_DB=data_platform
POSTGRES_USER=data_platform
POSTGRES_PASSWORD=replace-with-strong-postgres-password

# JWT signing configuration.
SECRET_KEY=replace-with-long-random-jwt-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Storage and browser access policy.
UPLOAD_DIR=/app/uploads
FRONTEND_ORIGINS=https://data.example.edu,https://www.data.example.edu

# Public HTTPS entrypoint and TLS termination hints.
PUBLIC_BASE_URL=https://data.example.edu
HTTPS_TERMINATION_ENABLED=true
TLS_CERT_PATH=/etc/nginx/certs/fullchain.pem
TLS_KEY_PATH=/etc/nginx/certs/privkey.pem
